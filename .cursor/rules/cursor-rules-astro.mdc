## Componente Astro — Estructura Base

```astro
---
// src/components/sections/Services.astro
import SectionTitle from '@components/ui/SectionTitle.astro';
import ServiceCard from '@components/ui/ServiceCard.astro';
import { services } from '@data/services';
---

<section id="servicios" class="py-20 bg-gray-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionTitle
      eyebrow="Lo que hacemos"
      title="Nuestros Servicios"
      description="Descripción breve de la propuesta de valor."
    />
    <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {services.map(service => (
        <ServiceCard service={service} />
      ))}
    </div>
  </div>
</section>
```

### Props con TypeScript — siempre tipadas

```astro
---
// src/components/ui/ServiceCard.astro
interface Props {
  service: {
    icon: string;
    title: string;
    description: string;
    href?: string;
  };
}
const { service } = Astro.props;
---

<div class="group rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
  <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50">
    <!-- ícono aquí -->
  </div>
  <h3 class="text-lg font-semibold text-gray-900">{service.title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-gray-500">{service.description}</p>
  {service.href && (
    <a
      href={service.href}
      class="mt-4 inline-flex items-center text-sm font-medium text-brand-600 hover:text-brand-700"
    >
      Ver más →
    </a>
  )}
</div>
```

