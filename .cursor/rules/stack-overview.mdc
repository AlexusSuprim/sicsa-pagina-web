## Configuración Base

### astro.config.mjs

```javascript
import { defineConfig } from 'astro/config';
import tailwind from '@astrojs/tailwind';
import icon from 'astro-icon';

export default defineConfig({
  // Para subir a Namecheap en la raíz del dominio
  site: 'https://tudominio.com',

  // Output estático — genera /dist con HTML/CSS/JS puro
  output: 'static',

  integrations: [
    tailwind({ applyBaseStyles: false }),
    icon(),
  ],

  // Comprimir HTML en producción
  compressHTML: true,

  build: {
    // Genera URLs limpias: /nosotros/ en vez de /nosotros.html
    format: 'directory',
  },
});
```

### tailwind.config.mjs

```javascript
import defaultTheme from 'tailwindcss/defaultTheme';

export default {
  content: ['./src/**/*.{astro,html,js,jsx,md,mdx,svelte,ts,tsx,vue}'],
  theme: {
    extend: {
      fontFamily: {
        sans: ['InterVariable', ...defaultTheme.fontFamily.sans],
        display: ['CalSans', ...defaultTheme.fontFamily.sans],
      },
      colors: {
        // Definir la paleta de la marca aquí
        brand: {
          50:  '#eff6ff',
          100: '#dbeafe',
          500: '#3b82f6',
          600: '#2563eb',
          700: '#1d4ed8',
          900: '#1e3a8a',
        },
      },
    },
  },
  plugins: [],
};
```

### tsconfig.json

```json
{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@data/*": ["src/data/*"]
    }
  }
}
```

