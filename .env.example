# Variables de entorno para build (Astro)
PUBLIC_SITE_URL=https://sicsagroup.com.gt

# Cloudflare Turnstile — Site Key (pública, va en el build)
# Crear widget en: https://dash.cloudflare.com/?to=/:account/turnstile
# Dominios permitidos: sicsagroup.com.gt, localhost
PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Opcional — código de verificación de Google Search Console (meta tag)
# PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_code_here

# Secret Key — NO va aquí (no es pública). En Namecheap, crear FUERA de public_html:
# /home/tu_usuario/contact.config.php (ver contact.config.php.example en la raíz del proyecto)
# Alternativa en cPanel: variable de entorno TURNSTILE_SECRET_KEY
