---
import Nav from '@components/layout/Nav.astro';
import MobileMenu from '@components/layout/MobileMenu.astro';
import Button from '@components/ui/Button.astro';
---

<header
  role="banner"
  class="sticky top-0 z-40 border-b border-gray-100 bg-white/95 backdrop-blur-md"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8">
    <a href="#inicio" class="flex shrink-0 items-center gap-3 sm:gap-4" aria-label="SICSA GROUP - Inicio">
      <img
        src="/images/logo_sicsa.jpg"
        alt="SICSA GROUP — Logística integral"
        width="180"
        height="52"
        class="h-10 w-auto sm:h-12"
        loading="eager"
        decoding="async"
      />
      <span class="hidden h-8 w-px bg-gray-200 sm:block" aria-hidden="true"></span>
      <img
        src="/images/logo_santal.png"
        alt="SANTAL GROUP"
        width="120"
        height="40"
        class="hidden h-7 w-auto sm:block sm:h-8"
        loading="eager"
        decoding="async"
      />
    </a>

    <nav class="hidden lg:block" aria-label="Navegación principal">
      <Nav />
    </nav>

    <div class="flex items-center gap-3">
      <Button href="#contacto" variant="primary" size="sm" class="hidden sm:inline-flex">
        Contáctanos
      </Button>
      <button
        id="mobile-menu-open"
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg text-brand-navy hover:bg-gray-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-red lg:hidden"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Abrir menú"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
  <MobileMenu />
</header>
