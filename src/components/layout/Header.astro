---
import Nav from '@components/layout/Nav.astro';
import Button from '@components/ui/Button.astro';
import SocialLinks from '@components/ui/SocialLinks.astro';
---

<header
  role="banner"
  class="sticky top-0 z-40 border-b border-gray-100 bg-white/95 backdrop-blur-md"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8">
    <a href="#inicio" class="flex min-w-0 shrink items-center gap-2 sm:gap-4" aria-label="SICSA GROUP - Inicio">
      <img
        src="/images/SICSA%20GROUP%20FINAL_FINAL.png"
        alt="SICSA GROUP — Logística integral"
        width="225"
        height="65"
        class="my-[15px] h-11 w-auto shrink-0 sm:h-[3.75rem]"
        loading="eager"
        decoding="async"
      />
      <span class="h-8 w-px shrink-0 bg-gray-200 sm:h-10" aria-hidden="true"></span>
      <img
        src="/images/Logo%20Santal%20Group_ORIGINAL_1.png"
        alt="SANTAL GROUP"
        width="150"
        height="50"
        class="h-7 w-auto shrink-0 sm:h-10"
        loading="eager"
        decoding="async"
      />
    </a>

    <nav class="hidden lg:block" aria-label="Navegación principal">
      <Nav />
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <div class="hidden items-center gap-2 sm:flex md:gap-3">
        <SocialLinks dark compact />
        <Button href="#contacto" variant="primary" size="sm">
          Contáctanos
        </Button>
      </div>
      <button
        id="mobile-menu-open"
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg text-brand-navy hover:bg-gray-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-red lg:hidden"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Abrir menú"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
</header>
