---
import Nav from '@components/layout/Nav.astro';
import Button from '@components/ui/Button.astro';
import SocialLinks from '@components/ui/SocialLinks.astro';
import LanguageToggle from '@components/layout/LanguageToggle.astro';
import type { Locale, SiteContent } from '@i18n/types';

interface Props {
  locale: Locale;
  content: SiteContent;
}

const { locale, content } = Astro.props;
const { ui, nav } = content;
const homeHash = nav.find((l) => l.section === 'home')?.hash ?? 'inicio';
const contactHash = nav.find((l) => l.section === 'contact')?.hash ?? 'contacto';
---

<header
  role="banner"
  class="sticky top-0 z-40 border-b border-gray-100 bg-white/95 backdrop-blur-md"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between gap-2 py-3 sm:gap-4">
    <a
      href={`#${homeHash}`}
      class="flex min-w-0 flex-1 items-center gap-2 overflow-hidden sm:gap-4 lg:flex-none"
      aria-label={ui.headerHomeAria}
    >
      <img
        src="/images/SICSA%20GROUP%20FINAL_FINAL.png"
        alt={ui.headerLogoAlt}
        width="2782"
        height="1083"
        class="my-[15px] h-11 w-auto shrink-0 sm:h-[3.75rem]"
        loading="eager"
        decoding="async"
      />
      <span class="h-8 w-px shrink-0 bg-gray-200 sm:h-10" aria-hidden="true"></span>
      <img
        src="/images/Logo%20Santal%20Group_ORIGINAL_1.png"
        alt="SANTAL GROUP"
        width="3000"
        height="931"
        class="my-[15px] h-11 w-auto shrink-0 sm:h-[3.75rem]"
        loading="eager"
        decoding="async"
      />
    </a>

    <nav class="hidden lg:block" aria-label={ui.mainNavAria}>
      <Nav links={nav} />
    </nav>

    <div class="flex shrink-0 items-center gap-1.5 sm:gap-2">
      <div class="hidden lg:block">
        <LanguageToggle locale={locale} variant="header" />
      </div>
      <div class="hidden items-center gap-2 sm:flex md:gap-3">
        <SocialLinks dark compact followPrefix={ui.socialFollowPrefix} />
        <Button href={`#${contactHash}`} variant="primary" size="sm">
          {ui.contactCta}
        </Button>
      </div>
      <button
        id="mobile-menu-open"
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg text-brand-navy hover:bg-gray-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-red lg:hidden"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label={ui.openMenuAria}
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
    </div>

    <!-- Móvil: fila dedicada para no solapar los logotipos -->
    <div
      class="flex items-center justify-end border-t border-gray-100 py-2 lg:hidden"
      aria-label={ui.languageLabel}
    >
      <LanguageToggle locale={locale} variant="header" />
    </div>
  </div>
</header>
