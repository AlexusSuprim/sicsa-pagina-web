---
import { navLinks } from '@data/nav-links';

interface Props {
  class?: string;
  onLinkClick?: string;
}

const { class: className = '', onLinkClick } = Astro.props;
---

<ul class={`flex items-center gap-1 ${className}`}>
  {
    navLinks.map((link) => (
      <li>
        <a
          href={link.href}
          class="rounded-lg px-4 py-2 text-sm font-medium text-brand-navy transition hover:bg-brand-navy-50 hover:text-brand-red focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-red"
          onclick={onLinkClick}
        >
          {link.label}
        </a>
      </li>
    ))
  }
</ul>
