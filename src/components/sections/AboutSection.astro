---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import type { SiteContent } from '@i18n/types';
import quienesSomosImage from '@/assets/images/about-quienes.jpg';
import adnLogisticoImage from '@/assets/images/about-dna.jpg';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const { about } = content;
const { quienesSomos, logisticDna, coreValues } = about;
---

<section data-section="about" class="bg-brand-navy py-16 sm:py-20 lg:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <div class="space-y-5" data-aos="fade-right">
        <h2 class="font-display text-3xl font-bold text-brand-steel sm:text-4xl lg:text-5xl">
          {quienesSomos.title}
        </h2>
        <ul class="space-y-3">
          {
            quienesSomos.highlights.map((item) => (
              <li class="flex items-start gap-3 text-base leading-relaxed text-white/90 sm:text-lg">
                <Icon name="mdi:check-circle" class="mt-1 h-5 w-5 shrink-0 text-brand-red" aria-hidden="true" />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="overflow-hidden rounded-2xl bg-brand-navy-light/30 shadow-xl" data-aos="fade-left">
        <Image
          src={quienesSomosImage}
          alt={quienesSomos.imageAlt}
          width={960}
          height={640}
          format="webp"
          quality={82}
          loading="lazy"
          class="aspect-[4/3] w-full object-cover object-center"
        />
      </div>
    </div>

    <div class="route-signature mt-16 rounded-2xl border border-white/10 bg-white/5 p-8 sm:p-10" data-aos="fade-up">
      <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2">
        <div class="overflow-hidden rounded-xl bg-brand-navy-light/20">
          <Image
            src={adnLogisticoImage}
            alt={logisticDna.imageAlt}
            width={960}
            height={640}
            format="webp"
            quality={82}
            loading="lazy"
            class="aspect-[4/3] w-full object-cover object-center"
          />
        </div>
        <div class="space-y-6">
          <h2 class="font-display text-3xl font-bold text-white sm:text-4xl">{logisticDna.title}</h2>
          <ul class="space-y-3">
            {
              logisticDna.highlights.map((item) => (
                <li class="flex items-start gap-3 text-base leading-relaxed text-white/85">
                  <Icon name="mdi:arrow-right-bold" class="mt-1 h-5 w-5 shrink-0 text-brand-red" aria-hidden="true" />
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
          <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
            {
              coreValues.map((value) => (
                <div class="rounded-xl border border-white/10 bg-brand-navy-light/40 p-4 text-center">
                  <Icon name={value.icon} class="mx-auto h-6 w-6 text-brand-red" aria-hidden="true" />
                  <p class="mt-2 text-sm font-bold text-white">{value.title}</p>
                  <p class="mt-1 text-xs leading-snug text-white/70">{value.description}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
