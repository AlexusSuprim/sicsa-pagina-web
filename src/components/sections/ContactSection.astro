---
import SectionTitle from '@components/ui/SectionTitle.astro';
import Button from '@components/ui/Button.astro';
import { Icon } from 'astro-icon/components';
import type { Locale, SiteContent } from '@i18n/types';
import {
  CONTACT_EMAIL,
  CONTACT_PHONE,
  ADDRESS,
  MAPS_EMBED_URL,
  MAPS_OPEN_URL,
  WHATSAPP_CHAT_URL,
  WHATSAPP_DISPLAY,
} from '@data/site';

interface Props {
  content: SiteContent;
  locale: Locale;
}

const { content, locale } = Astro.props;
const contact = content.ui.contact;
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
const isTurnstileEnabled = turnstileSiteKey.length > 0;
---

<section data-section="contact" class="bg-brand-navy-50 py-16 sm:py-20 lg:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionTitle
      eyebrow={contact.eyebrow}
      title={contact.title}
      description={contact.description}
      align="center"
    />

    <div class="mt-12 grid grid-cols-1 gap-12 lg:grid-cols-2">
      <div class="space-y-8" data-aos="fade-right">
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-brand-red/10 text-brand-red">
              <Icon name="mdi:map-marker" class="h-5 w-5" aria-hidden="true" />
            </div>
            <div>
              <h3 class="font-semibold text-brand-navy">{contact.addressLabel}</h3>
              <address class="mt-1 not-italic text-sm leading-relaxed text-gray-600">
                <a
                  href={MAPS_OPEN_URL}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="transition hover:text-brand-red"
                >
                  {ADDRESS.street}<br />
                  {ADDRESS.building}<br />
                  {ADDRESS.city}, {ADDRESS.country}
                </a>
              </address>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-brand-red/10 text-brand-red">
              <Icon name="mdi:phone" class="h-5 w-5" aria-hidden="true" />
            </div>
            <div>
              <h3 class="font-semibold text-brand-navy">{contact.phoneLabel}</h3>
              <a
                href={`tel:${CONTACT_PHONE.replace(/\s/g, '')}`}
                class="mt-1 text-sm text-gray-600 hover:text-brand-red"
              >
                {CONTACT_PHONE}
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-brand-red/10 text-brand-red">
              <Icon name="mdi:email" class="h-5 w-5" aria-hidden="true" />
            </div>
            <div>
              <h3 class="font-semibold text-brand-navy">{contact.emailLabel}</h3>
              <a href={`mailto:${CONTACT_EMAIL}`} class="mt-1 text-sm text-gray-600 hover:text-brand-red">
                {CONTACT_EMAIL}
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[#25D366]/10 text-[#25D366]">
              <Icon name="mdi:whatsapp" class="h-5 w-5" aria-hidden="true" />
            </div>
            <div>
              <h3 class="font-semibold text-brand-navy">{contact.whatsappLabel}</h3>
              <a
                href={WHATSAPP_CHAT_URL}
                data-whatsapp-link
                target="_blank"
                rel="noopener noreferrer"
                class="mt-1 text-sm text-gray-600 hover:text-brand-red"
              >
                {WHATSAPP_DISPLAY}
              </a>
            </div>
          </div>
        </div>

        <div class="overflow-hidden rounded-2xl shadow-sm">
          <iframe
            src={MAPS_EMBED_URL}
            width="100%"
            height="280"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title={contact.mapTitle}
            class="w-full"
          ></iframe>
        </div>
      </div>

      <div
        class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm sm:p-8"
        data-aos="fade-left"
      >
        <h3 class="text-xl font-bold text-brand-navy">{contact.formTitle}</h3>
        <p class="mt-2 text-sm text-gray-500">{contact.requiredHint}</p>

        <form
          id="contact-form"
          class="mt-6 space-y-5"
          novalidate
          data-locale={locale}
          data-success-message={contact.successMessage}
          data-error-message={contact.errorMessage}
          data-connection-error={contact.connectionError}
          data-submit-label={contact.submitLabel}
          data-submitting-label={contact.submittingLabel}
          data-turnstile-required={isTurnstileEnabled ? 'true' : 'false'}
          data-turnstile-required-message={contact.turnstileRequired}
        >
          <input type="hidden" name="lang" value={locale} />

          <div>
            <label for="name" class="block text-sm font-medium text-gray-700">
              {contact.nameLabel} <span class="text-brand-red">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              maxlength="100"
              autocomplete="name"
              class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-3 text-sm shadow-sm outline-none transition focus:border-brand-red focus:ring-2 focus:ring-brand-red/20"
              placeholder={contact.namePlaceholder}
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-gray-700">
              {contact.emailLabelField} <span class="text-brand-red">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              maxlength="150"
              autocomplete="email"
              class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-3 text-sm shadow-sm outline-none transition focus:border-brand-red focus:ring-2 focus:ring-brand-red/20"
              placeholder={contact.emailPlaceholder}
            />
          </div>

          <div>
            <label for="address" class="block text-sm font-medium text-gray-700">
              {contact.addressLabelField} <span class="text-brand-red">*</span>
            </label>
            <input
              type="text"
              id="address"
              name="address"
              required
              maxlength="200"
              autocomplete="street-address"
              class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-3 text-sm shadow-sm outline-none transition focus:border-brand-red focus:ring-2 focus:ring-brand-red/20"
              placeholder={contact.addressPlaceholder}
            />
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium text-gray-700">
              {contact.phoneLabelField} <span class="text-brand-red">*</span>
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              maxlength="30"
              autocomplete="tel"
              class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-3 text-sm shadow-sm outline-none transition focus:border-brand-red focus:ring-2 focus:ring-brand-red/20"
              placeholder={contact.phonePlaceholder}
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-gray-700">
              {contact.messageLabel} <span class="text-brand-red">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              maxlength="2000"
              class="mt-1 block w-full resize-none rounded-lg border border-gray-300 px-4 py-3 text-sm shadow-sm outline-none transition focus:border-brand-red focus:ring-2 focus:ring-brand-red/20"
              placeholder={contact.messagePlaceholder}
            ></textarea>
          </div>

          {
            isTurnstileEnabled ? (
              <div
                class="cf-turnstile"
                data-sitekey={turnstileSiteKey}
                data-theme="light"
              />
            ) : import.meta.env.DEV ? (
              <p class="rounded-lg bg-amber-50 p-3 text-xs text-amber-700">
                {contact.turnstileHint}
              </p>
            ) : null
          }

          <div id="form-success" class="hidden rounded-lg bg-green-50 p-4 text-sm text-green-700" role="status">
            {contact.successMessage}
          </div>
          <div id="form-error" class="hidden rounded-lg bg-red-50 p-4 text-sm text-red-700" role="alert">
            {contact.errorMessage}
          </div>

          <Button type="submit" variant="primary" id="submit-btn" class="w-full">
            {contact.submitLabel}
          </Button>
        </form>
      </div>
    </div>
  </div>
</section>

{
  isTurnstileEnabled && (
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  )
}

<script>
  interface TurnstileApi {
    reset: (element: Element) => void;
  }

  interface WindowWithTurnstile extends Window {
    turnstile?: TurnstileApi;
  }

  const win = window as WindowWithTurnstile;
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const success = document.getElementById('form-success');
  const error = document.getElementById('form-error');

  if (form && btn && success && error) {
    const defaultError = form.dataset.errorMessage ?? '';
    const connectionError = form.dataset.connectionError ?? '';
    const submitLabel = form.dataset.submitLabel ?? '';
    const submittingLabel = form.dataset.submittingLabel ?? '';
    const turnstileRequired = form.dataset.turnstileRequired === 'true';
    const turnstileRequiredMessage = form.dataset.turnstileRequiredMessage ?? '';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      success.classList.add('hidden');
      error.classList.add('hidden');

      const turnstileInput = form.querySelector<HTMLInputElement>(
        'input[name="cf-turnstile-response"]',
      );

      if (turnstileRequired && !turnstileInput?.value) {
        error.textContent = turnstileRequiredMessage;
        error.classList.remove('hidden');
        return;
      }

      btn.disabled = true;
      btn.textContent = submittingLabel;

      try {
        const data = new FormData(form);
        if (turnstileInput?.value) {
          data.append('cf-turnstile-response', turnstileInput.value);
        }

        const res = await fetch('/contact.php', { method: 'POST', body: data });
        const json = (await res.json()) as { success: boolean; message?: string };

        if (json.success) {
          success.classList.remove('hidden');
          const langValue = form.querySelector<HTMLInputElement>('input[name="lang"]')?.value ?? 'es';
          form.reset();
          const langInput = form.querySelector<HTMLInputElement>('input[name="lang"]');
          if (langInput) {
            langInput.value = langValue;
          }
          const widget = form.querySelector('.cf-turnstile');
          if (win.turnstile && widget) {
            win.turnstile.reset(widget);
          }
        } else {
          error.textContent = json.message ?? defaultError;
          error.classList.remove('hidden');
        }
      } catch {
        error.textContent = connectionError;
        error.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.textContent = submitLabel;
      }
    });
  }
</script>
