---
import Button from '@components/ui/Button.astro';
---

<section class="py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div
      class="relative overflow-hidden rounded-3xl bg-brand-red px-8 py-16 text-center sm:px-16"
      data-aos="fade-up"
    >
      <div class="absolute -right-10 -top-10 h-40 w-40 rounded-full bg-white/10"></div>
      <div class="absolute -bottom-10 -left-10 h-32 w-32 rounded-full bg-white/10"></div>
      <div class="relative">
        <h2 class="font-display text-3xl font-bold text-white sm:text-4xl">
          Construyamos el futuro juntos
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-lg text-white/85">
          Conectamos, aceleramos y protegemos cada operación logística que deposita en nuestras
          manos. Hablemos de cómo podemos impulsar su negocio.
        </p>
        <div class="mt-8">
          <Button href="#contacto" variant="light" size="lg">
            Solicitar información
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>
