---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import type { SiteContent } from '@i18n/types';
import flotillaPropiaImage from '@/assets/images/flotilla-propia.png';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const { fleet } = content;
---

<section class="bg-brand-surface py-14 sm:py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2">
      <div data-aos="fade-right">
        <p class="text-sm font-semibold uppercase tracking-wide text-brand-red">{fleet.eyebrow}</p>
        <h2 class="mt-2 font-display text-3xl font-bold text-brand-navy sm:text-4xl">
          {fleet.title}
        </h2>
        <p class="mt-4 max-w-lg text-base leading-relaxed text-gray-600">
          {fleet.description}
        </p>
        <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2">
          {
            fleet.units.map((unit) => (
              <div class="flex items-start gap-3 rounded-xl border border-brand-navy-100 bg-white p-4">
                <Icon name={unit.icon} class="mt-0.5 h-5 w-5 shrink-0 text-brand-red" aria-hidden="true" />
                <div>
                  <p class="font-semibold text-brand-navy">{unit.title}</p>
                  <p class="mt-1 text-sm text-gray-600">{unit.description}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
      <div
        class="overflow-hidden rounded-2xl border border-brand-navy-100 bg-brand-navy shadow-lg"
        data-aos="fade-left"
      >
        <Image
          src={flotillaPropiaImage}
          alt={fleet.imageAlt}
          width={1391}
          height={752}
          format="webp"
          quality={85}
          loading="lazy"
          class="aspect-[1391/752] w-full object-cover object-[center_45%] sm:object-center"
        />
      </div>
    </div>
  </div>
</section>
