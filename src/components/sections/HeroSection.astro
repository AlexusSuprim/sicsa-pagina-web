---
import { Image } from 'astro:assets';
import Button from '@components/ui/Button.astro';
import Badge from '@components/ui/Badge.astro';
import { SITE_TAGLINE, SITE_DESCRIPTION } from '@data/site';
import heroImage from '@/assets/images/hero-logistics.jpg';
---

<section
  id="inicio"
  class="relative flex min-h-[85vh] items-center overflow-hidden bg-brand-navy"
>
  <Image
    src={heroImage}
    alt="Contenedores de carga en puerto logístico"
    width={1920}
    height={1080}
    format="webp"
    quality={85}
    loading="eager"
    class="absolute inset-0 h-full w-full object-cover opacity-40"
  />
  <div class="absolute inset-0 bg-gradient-to-r from-brand-navy/95 via-brand-navy/80 to-brand-navy/50"></div>

  <div class="relative mx-auto max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8">
    <div class="max-w-3xl">
      <div class="animate-hero flex flex-wrap items-center gap-3">
        <Badge text="SICSA GROUP" />
        <span class="text-sm font-medium text-white/70">· SANTAL GROUP</span>
      </div>
      <h1 class="animate-hero-delay mt-6 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        {SITE_TAGLINE}
      </h1>
      <p class="animate-hero-delay-2 mt-6 max-w-2xl text-lg leading-relaxed text-white/85 sm:text-xl">
        {SITE_DESCRIPTION}
      </p>
      <div class="animate-hero-delay-2 mt-10 flex flex-col gap-4 sm:flex-row">
        <Button href="#servicios" variant="primary" size="lg">
          Nuestros servicios
        </Button>
        <Button href="#contacto" variant="outline" size="lg">
          Contáctanos
        </Button>
      </div>
    </div>
  </div>
</section>
