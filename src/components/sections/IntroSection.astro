---
import SectionTitle from '@components/ui/SectionTitle.astro';
import { aboutContent } from '@data/services';
---

<section class="py-16 sm:py-20 lg:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionTitle
      eyebrow="Bienvenidos"
      title="Soluciones logísticas integrales"
      description={aboutContent.intro}
      align="center"
    />
    <p class="mx-auto mt-6 max-w-3xl text-center text-base leading-relaxed text-gray-600" data-aos="fade-up">
      {aboutContent.evolution}
    </p>
  </div>
</section>
