---
import { Icon } from 'astro-icon/components';
import type { SiteContent } from '@i18n/types';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const { intro, ui } = content;
---

<section class="border-y border-brand-navy-100 bg-brand-surface py-12 sm:py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-6 lg:grid-cols-4 lg:gap-8">
      {
        intro.stats.map((stat, index) => (
          <div class="text-center" data-aos="fade-up" data-aos-delay={index * 80}>
            <div class="mx-auto mb-3 inline-flex h-12 w-12 items-center justify-center rounded-full bg-brand-red/10 text-brand-red">
              <Icon name={stat.icon} class="h-6 w-6" aria-hidden="true" />
            </div>
            <p
              class="font-display text-3xl font-bold text-brand-navy sm:text-4xl"
              data-stat-counter
              data-stat-value={stat.value}
            >
              {stat.value}
            </p>
            <p class="mt-1 text-sm text-gray-600">{stat.label}</p>
          </div>
        ))
      }
    </div>

    <h2 class="sr-only">{ui.introPillarsHeading}</h2>
    <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
      {
        intro.pillars.map((pillar, index) => (
          <div
            class="rounded-2xl border border-brand-navy-100 bg-white p-6 shadow-sm"
            data-aos="fade-up"
            data-aos-delay={index * 100}
          >
            <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-full bg-brand-navy text-white">
              <Icon name={pillar.icon} class="h-5 w-5" aria-hidden="true" />
            </div>
            <h3 class="text-lg font-bold text-brand-navy">{pillar.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-gray-600">{pillar.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  function parseStatValue(raw) {
    const match = raw.match(/\d+/);
    return match ? Number(match[0]) : null;
  }

  function initStatCounters() {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const counters = document.querySelectorAll('[data-stat-counter]');

    counters.forEach((el) => {
      const raw = el.getAttribute('data-stat-value') ?? el.textContent ?? '';
      const target = parseStatValue(raw);
      if (target === null || prefersReduced) return;

      const suffix = raw.replace(/\d+/, '');
      let started = false;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting || started) return;
            started = true;
            observer.disconnect();

            const duration = 900;
            const start = performance.now();

            function tick(now) {
              const progress = Math.min((now - start) / duration, 1);
              const value = Math.round(target * progress);
              el.textContent = `${value}${suffix}`;
              if (progress < 1) requestAnimationFrame(tick);
            }

            requestAnimationFrame(tick);
          });
        },
        { threshold: 0.4 }
      );

      observer.observe(el);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStatCounters);
  } else {
    initStatCounters();
  }
</script>
