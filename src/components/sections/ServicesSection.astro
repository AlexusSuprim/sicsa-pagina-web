---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import SectionTitle from '@components/ui/SectionTitle.astro';
import CourierServicePanel from '@components/ui/CourierServicePanel.astro';
import type { SiteContent } from '@i18n/types';
import maritimeImage from '@/assets/images/transporte-maritimo.png';
import airImage from '@/assets/images/carga-aerea.png';
import landImage from '@/assets/images/transporte-terrestre-internacional.png';
import customsImage from '@/assets/images/servicio-aduanal.png';
import warehousingImage from '@/assets/images/servicio-almacenaje.png';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const { services, ui } = content;

const imageMap = {
  maritime: maritimeImage,
  air: airImage,
  land: landImage,
  customs: customsImage,
  warehousing: warehousingImage,
} as const;

const imageDimensions: Record<string, { width: number; height: number }> = {
  maritime: { width: 1225, height: 740 },
  air: { width: 1050, height: 1008 },
  land: { width: 976, height: 1078 },
  customs: { width: 1536, height: 1024 },
  warehousing: { width: 1120, height: 959 },
};

const defaultImageDimensions = { width: 800, height: 500 } as const;

const imagePosition: Record<string, string> = {
  maritime: 'object-cover object-[72%_42%] sm:object-[68%_center]',
  air: 'object-cover object-[50%_24%] sm:object-[50%_26%]',
  land: 'object-cover object-[50%_46%] sm:object-[50%_48%]',
  customs: 'object-cover object-[50%_45%] sm:object-center',
  warehousing: 'object-cover object-[48%_52%] sm:object-[50%_50%]',
};
---

<section data-section="services" class="py-16 sm:py-20 lg:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionTitle
      eyebrow={services.eyebrow}
      title={services.title}
      description={services.description}
      align="center"
    />

    <div class="mt-10 flex flex-wrap items-center justify-center gap-4" data-aos="fade-up">
      {
        services.multimodalModes.map((mode) => (
          <div class="flex items-center gap-2 rounded-full bg-brand-navy-50 px-5 py-2.5">
            <Icon name={mode.icon} class="h-5 w-5 text-brand-red" aria-hidden="true" />
            <span class="text-sm font-semibold text-brand-navy">{mode.label}</span>
          </div>
        ))
      }
    </div>

    <div class="mt-14 grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
      {
        services.items.map((service, index) => {
          const image = imageMap[service.imageKey as keyof typeof imageMap] ?? maritimeImage;
          const objectClass = imagePosition[service.imageKey] ?? 'object-cover object-center';
          const dimensions = imageDimensions[service.imageKey] ?? defaultImageDimensions;

          return (
            <article
              class="service-card-elevated overflow-hidden rounded-2xl border border-brand-navy-100 bg-white shadow-sm"
              data-aos="fade-up"
              data-aos-delay={index * 80}
            >
              <div class="relative aspect-[16/10] overflow-hidden bg-brand-navy-50">
                <Image
                  src={image}
                  alt={service.title}
                  width={dimensions.width}
                  height={dimensions.height}
                  format="webp"
                  quality={['maritime', 'air', 'land', 'customs', 'warehousing'].includes(service.imageKey) ? 85 : 80}
                  loading="lazy"
                  class={`h-full w-full ${objectClass}`}
                />
                <div class="absolute inset-0 bg-brand-navy/20" />
                <span class="absolute left-4 top-4 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white/95 text-brand-navy">
                  <Icon name={service.icon} class="h-5 w-5" aria-hidden="true" />
                </span>
              </div>
              <div class="p-6">
                <p class="text-xs font-semibold uppercase tracking-wide text-brand-red">{service.tagline}</p>
                <h3 class="mt-1 text-xl font-bold text-brand-navy">{service.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-gray-600">{service.description}</p>
                <details class="group mt-4">
                  <summary class="cursor-pointer text-sm font-semibold text-brand-navy marker:content-none">
                    <span class="inline-flex items-center gap-1">
                      {ui.servicesViewCapabilities}
                      <Icon
                        name="mdi:chevron-down"
                        class="h-4 w-4 transition group-open:rotate-180"
                        aria-hidden="true"
                      />
                    </span>
                  </summary>
                  <ul class="mt-3 space-y-2 border-t border-gray-100 pt-3">
                    {
                      service.features.map((feature) => (
                        <li class="flex items-start gap-2 text-sm text-gray-600">
                          <Icon
                            name="mdi:check-circle"
                            class="mt-0.5 h-4 w-4 shrink-0 text-brand-red"
                            aria-hidden="true"
                          />
                          <span>{feature}</span>
                        </li>
                      ))
                    }
                  </ul>
                </details>
              </div>
            </article>
          );
        })
      }
    </div>

    <div class="mt-8">
      <CourierServicePanel content={content} />
    </div>
  </div>
</section>
