---
import SectionTitle from '@components/ui/SectionTitle.astro';
import ServiceCard from '@components/ui/ServiceCard.astro';
import { Icon } from 'astro-icon/components';
import { services } from '@data/services';
import { multimodalModes } from '@data/company-stats';
---

<section id="servicios" class="py-16 sm:py-20 lg:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionTitle
      eyebrow="Servicios"
      title="Logística integral para su negocio"
      description="Nacimos expertos en aduanas y evolucionamos contigo. Hoy dominamos el transporte aéreo, marítimo y terrestre en toda la región."
      align="center"
    />

    <div class="mt-10 flex flex-wrap items-center justify-center gap-6" data-aos="fade-up">
      {
        multimodalModes.map((mode) => (
          <div class="flex items-center gap-2 rounded-full bg-brand-navy-50 px-5 py-2.5">
            <Icon name={mode.icon} class="h-5 w-5 text-brand-red" aria-hidden="true" />
            <span class="text-sm font-semibold text-brand-navy">{mode.label}</span>
          </div>
        ))
      }
    </div>

    <div class="mt-16 space-y-8">
      {services.map((service, index) => <ServiceCard service={service} index={index} />)}
    </div>
  </div>
</section>
