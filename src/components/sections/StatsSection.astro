---
import { Icon } from 'astro-icon/components';
import { companyStats } from '@data/company-stats';
---

<section class="border-y border-gray-100 bg-white py-12 sm:py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-6 lg:grid-cols-4 lg:gap-8">
      {
        companyStats.map((stat, index) => (
          <div
            class="text-center"
            data-aos="fade-up"
            data-aos-delay={index * 100}
          >
            <div class="mx-auto mb-3 inline-flex h-12 w-12 items-center justify-center rounded-full bg-brand-red/10 text-brand-red">
              <Icon name={stat.icon} class="h-6 w-6" aria-hidden="true" />
            </div>
            <p class="font-display text-3xl font-bold text-brand-navy sm:text-4xl">{stat.value}</p>
            <p class="mt-1 text-sm text-gray-600">{stat.label}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
