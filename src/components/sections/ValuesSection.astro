---
import SectionTitle from '@components/ui/SectionTitle.astro';
import ValueCard from '@components/ui/ValueCard.astro';
import { values } from '@data/values';
---

<section class="py-16 sm:py-20 lg:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <SectionTitle
      eyebrow="Nuestros valores"
      title="Los principios que nos guían"
      description="Cada operación que realizamos se sustenta en valores que fortalecen la confianza de nuestros clientes."
      align="center"
    />
    <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {values.map((value, index) => <ValueCard value={value} index={index} />)}
    </div>
  </div>
</section>
