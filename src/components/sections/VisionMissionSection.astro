---
import { Icon } from 'astro-icon/components';
import { mission, vision } from '@data/values';
---

<section class="bg-brand-navy-50 py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
      <div
        class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm"
        data-aos="fade-up"
      >
        <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand-red/10 text-brand-red">
          <Icon name="mdi:target" class="h-6 w-6" aria-hidden="true" />
        </div>
        <h3 class="text-xl font-bold text-brand-navy">Misión</h3>
        <p class="mt-3 leading-relaxed text-gray-600">{mission}</p>
      </div>
      <div
        class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm"
        data-aos="fade-up"
        data-aos-delay="100"
      >
        <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand-blue/10 text-brand-blue">
          <Icon name="mdi:eye" class="h-6 w-6" aria-hidden="true" />
        </div>
        <h3 class="text-xl font-bold text-brand-navy">Visión</h3>
        <p class="mt-3 leading-relaxed text-gray-600">{vision}</p>
      </div>
    </div>
  </div>
</section>
