---
import { Icon } from 'astro-icon/components';
import {
  COURIER_WHATSAPP_CHAT_URL,
  COURIER_WHATSAPP_URL,
  courierService,
} from '@data/courier';

const { socialLinks } = courierService;

const socialItems = [
  { name: 'Facebook', href: socialLinks.facebook, icon: 'mdi:facebook' },
  { name: 'Instagram', href: socialLinks.instagram, icon: 'mdi:instagram' },
] as const;
---

<details
  id="courier"
  class="courier-panel group overflow-hidden rounded-2xl border-2 border-brand-red/20 bg-white shadow-sm open:border-brand-red/35 open:shadow-md"
  data-aos="fade-up"
>
  <summary
    class="courier-panel__summary grid cursor-pointer list-none grid-cols-1 lg:grid-cols-2"
  >
    <div class="order-2 flex flex-col justify-center p-6 sm:p-8 lg:order-1 lg:p-10">
      <div
        class="mb-4 inline-flex h-[3.75rem] items-center justify-center self-start rounded-xl border border-gray-100 bg-white px-3"
      >
        <img
          src={courierService.logoImage}
          alt={`Logotipo ${courierService.title}`}
          width="180"
          height="60"
          loading="lazy"
          decoding="async"
          class="h-[2.8125rem] w-auto max-w-[11.25rem] object-contain"
        />
      </div>
      <p class="text-sm font-semibold uppercase tracking-wide text-brand-red">
        {courierService.tagline}
      </p>
      <h3 class="mt-1 text-2xl font-bold text-brand-navy">{courierService.title}</h3>
      <p class="mt-3 text-base leading-relaxed text-gray-600">{courierService.description}</p>
      <span
        class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-brand-red transition group-open:text-brand-red-dark"
      >
        <span class="group-open:hidden">Ver detalles del servicio</span>
        <span class="hidden group-open:inline">Ocultar detalles</span>
        <Icon
          name="mdi:chevron-down"
          class="h-5 w-5 transition-transform duration-200 group-open:rotate-180"
          aria-hidden="true"
        />
      </span>
    </div>

    <div class="relative order-1 aspect-[4/3] lg:order-2 lg:aspect-auto lg:min-h-[320px]">
      <img
        src={courierService.image}
        alt={courierService.imageAlt}
        width="600"
        height="400"
        loading="lazy"
        decoding="async"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-brand-navy/25"></div>
      <span
        class="absolute left-4 top-4 rounded-full bg-brand-red px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white"
      >
        Servicio dedicado
      </span>
    </div>
  </summary>

  <div class="border-t border-gray-100 bg-brand-navy-50/40 px-6 py-8 sm:px-8 lg:px-10">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-12">
      <div>
        <h4 class="text-lg font-bold text-brand-navy">¿Cómo funciona?</h4>
        <p class="mt-3 text-base leading-relaxed text-gray-600">
          {courierService.extendedDescription}
        </p>
        <ol class="mt-5 space-y-3">
          {
            courierService.steps.map((step, index) => (
              <li class="flex items-start gap-3 text-sm text-gray-600">
                <span
                  class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-red text-xs font-bold text-white"
                  aria-hidden="true"
                >
                  {index + 1}
                </span>
                <span>{step}</span>
              </li>
            ))
          }
        </ol>
      </div>

      <div>
        <h4 class="text-lg font-bold text-brand-navy">Beneficios del servicio</h4>
        <ul class="mt-4 space-y-2">
          {
            courierService.features.map((feature) => (
              <li class="flex items-start gap-2 text-sm text-gray-600">
                <Icon
                  name="mdi:check-circle"
                  class="mt-0.5 h-4 w-4 shrink-0 text-brand-red"
                  aria-hidden="true"
                />
                <span>{feature}</span>
              </li>
            ))
          }
        </ul>

        <div class="mt-8 rounded-xl border border-gray-100 bg-white p-5 shadow-sm">
          <h4 class="text-base font-bold text-brand-navy">Contacto Courier</h4>
          <p class="mt-1 text-sm text-gray-500">
            Redes y WhatsApp exclusivos de SICSA Courier.
          </p>

          <div class="mt-4 flex items-center gap-3">
            {
              socialItems.map((item) => (
                <a
                  href={item.href}
                  class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-brand-navy-50 text-brand-navy transition hover:bg-brand-navy hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-red"
                  aria-label={`SICSA Courier en ${item.name}`}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <Icon name={item.icon} class="h-5 w-5" aria-hidden="true" />
                </a>
              ))
            }
          </div>

          <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a
              href={COURIER_WHATSAPP_CHAT_URL}
              data-whatsapp-link
              data-whatsapp-desktop={COURIER_WHATSAPP_URL}
              class="inline-flex items-center justify-center rounded-lg bg-[#25D366] px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-[#1fb855] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#25D366]"
              aria-label="Contactar SICSA Courier por WhatsApp"
            >
              <Icon name="mdi:whatsapp" class="mr-2 h-5 w-5" aria-hidden="true" />
              WhatsApp Courier
            </a>
            <span class="text-sm text-gray-500">{courierService.whatsappPhoneDisplay}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</details>

<style>
  .courier-panel__summary::-webkit-details-marker {
    display: none;
  }

  .courier-panel__summary::marker {
    content: '';
  }
</style>
