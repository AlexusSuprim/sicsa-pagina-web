---
import { Icon } from 'astro-icon/components';
import type { ServiceItem } from '@data/services';

interface Props {
  service: ServiceItem;
  index: number;
}

const { service, index } = Astro.props;
const isEven = index % 2 === 0;
---

<article
  class="overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm"
  data-aos="fade-up"
  data-aos-delay={index * 100}
>
  <div class={`grid grid-cols-1 lg:grid-cols-2 ${isEven ? '' : 'lg:[&>*:first-child]:order-2'}`}>
    <div class="relative aspect-[4/3] lg:aspect-auto lg:min-h-[320px]">
      <img
        src={service.image}
        alt={`Ilustración del servicio de ${service.title}`}
        width="600"
        height="400"
        loading="lazy"
        decoding="async"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-brand-navy/20"></div>
    </div>
    <div class="flex flex-col justify-center p-6 sm:p-8 lg:p-10">
      <div
        class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand-navy-50 text-brand-navy"
      >
        <Icon name={service.icon} class="h-6 w-6" aria-hidden="true" />
      </div>
      <h3 class="text-2xl font-bold text-brand-navy">{service.title}</h3>
      <p class="mt-3 text-base leading-relaxed text-gray-600">{service.description}</p>
      <ul class="mt-5 space-y-2">
        {
          service.features.map((feature) => (
            <li class="flex items-start gap-2 text-sm text-gray-600">
              <Icon
                name="mdi:check-circle"
                class="mt-0.5 h-4 w-4 shrink-0 text-brand-red"
                aria-hidden="true"
              />
              <span>{feature}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</article>
