---
import { Icon } from 'astro-icon/components';
import { SOCIAL_LINKS } from '@data/site';

interface Props {
  light?: boolean;
}

const { light = false } = Astro.props;

const linkClass = light
  ? 'text-white/70 hover:text-white'
  : 'text-gray-500 hover:text-brand-navy';

const socialItems = [
  { name: 'Facebook', href: SOCIAL_LINKS.facebook, icon: 'mdi:facebook' },
  { name: 'X (Twitter)', href: SOCIAL_LINKS.twitter, icon: 'mdi:twitter' },
  { name: 'LinkedIn', href: SOCIAL_LINKS.linkedin, icon: 'mdi:linkedin' },
] as const;
---

<div class="flex items-center gap-4">
  {
    socialItems.map((item) => (
      <a
        href={item.href}
        class={`inline-flex h-10 w-10 items-center justify-center rounded-full transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-red ${linkClass}`}
        aria-label={`Síguenos en ${item.name}`}
        target={item.href !== '#' ? '_blank' : undefined}
        rel={item.href !== '#' ? 'noopener noreferrer' : undefined}
      >
        <Icon name={item.icon} class="h-5 w-5" aria-hidden="true" />
      </a>
    ))
  }
</div>
