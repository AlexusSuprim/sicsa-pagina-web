---
import { Icon } from 'astro-icon/components';
import { SOCIAL_LINKS } from '@data/site';

interface Props {
  light?: boolean;
  /** Iconos oscuros para fondos claros (encabezado) */
  dark?: boolean;
  /** Tamaño reducido para el encabezado */
  compact?: boolean;
}

const { light = false, dark = false, compact = false } = Astro.props;

const linkClass = light
  ? 'text-white/70 hover:text-white'
  : dark
    ? 'text-gray-900 hover:text-brand-navy'
    : 'text-gray-500 hover:text-brand-navy';

const buttonClass = compact ? 'h-8 w-8' : 'h-10 w-10';
const iconClass = compact ? 'h-4 w-4' : 'h-5 w-5';
const containerClass = compact ? 'gap-2' : 'gap-4';

interface SocialItem {
  name: string;
  href: string;
  icon: string;
}

const socialItems: SocialItem[] = [
  { name: 'Facebook', href: SOCIAL_LINKS.facebook, icon: 'mdi:facebook' },
  { name: 'Instagram', href: SOCIAL_LINKS.instagram, icon: 'mdi:instagram' },
  ...(SOCIAL_LINKS.linkedin
    ? [{ name: 'LinkedIn', href: SOCIAL_LINKS.linkedin, icon: 'mdi:linkedin' }]
    : []),
].filter((item) => item.href.length > 0);
---

<div class:list={['flex items-center', containerClass]}>
  {
    socialItems.map((item) => (
      <a
        href={item.href}
        class:list={[
          'inline-flex items-center justify-center rounded-full transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-red',
          buttonClass,
          linkClass,
        ]}
        aria-label={`Síguenos en ${item.name}`}
        target="_blank"
        rel="noopener noreferrer"
      >
        <Icon name={item.icon} class={iconClass} aria-hidden="true" />
      </a>
    ))
  }
</div>
