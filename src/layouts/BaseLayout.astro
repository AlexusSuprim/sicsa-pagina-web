---
import '@/styles/globals.css';
import 'aos/dist/aos.css';
import Header from '@components/layout/Header.astro';
import MobileMenu from '@components/layout/MobileMenu.astro';
import Footer from '@components/layout/Footer.astro';
import WhatsAppButton from '@components/layout/WhatsAppButton.astro';
import {
  SITE_NAME,
  SITE_URL,
  CONTACT_EMAIL,
  CONTACT_PHONE,
  ADDRESS,
  MAP_LOCATION,
  getActiveSocialUrls,
} from '@data/site';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalUrl?: string;
}

const {
  title,
  description,
  image = '/images/og-default.jpg',
  canonicalUrl = Astro.url.href,
} = Astro.props;

const fullTitle = `${title} | ${SITE_NAME}`;
const ogImage = new URL(image, SITE_URL).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: SITE_NAME,
  description,
  url: SITE_URL,
  email: CONTACT_EMAIL,
  telephone: CONTACT_PHONE,
  address: {
    '@type': 'PostalAddress',
    streetAddress: `${ADDRESS.street}, ${ADDRESS.building}`,
    addressLocality: ADDRESS.city,
    addressCountry: 'GT',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: MAP_LOCATION.latitude,
    longitude: MAP_LOCATION.longitude,
  },
  sameAs: getActiveSocialUrls(),
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="es_GT" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{fullTitle}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="bg-white text-gray-900">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-brand-red focus:px-4 focus:py-2 focus:text-white"
    >
      Saltar al contenido
    </a>

    <Header />
    <MobileMenu />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />

    <script>
      import AOS from 'aos';

      const MOBILE_UA_PATTERN =
        /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i;

      function initWhatsAppLinks(): void {
        const links = document.querySelectorAll<HTMLAnchorElement>('[data-whatsapp-link]');
        const isMobile = MOBILE_UA_PATTERN.test(navigator.userAgent);

        links.forEach((link) => {
          if (isMobile) {
            link.removeAttribute('target');
            link.removeAttribute('rel');
          } else {
            const desktopHref = link.dataset.whatsappDesktop;
            if (desktopHref) {
              link.href = desktopHref;
            }
            link.setAttribute('target', '_blank');
            link.setAttribute('rel', 'noopener noreferrer');
          }

          let isNavigating = false;
          link.addEventListener(
            'click',
            (event) => {
              if (isNavigating) {
                event.preventDefault();
                return;
              }
              isNavigating = true;
              window.setTimeout(() => {
                isNavigating = false;
              }, 3000);
            },
            { passive: false }
          );
        });
      }

      function initAos(): void {
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        AOS.init({
          duration: 600,
          easing: 'ease-out-cubic',
          once: true,
          offset: 80,
          disable: prefersReduced,
        });
      }

      function initPageScripts(): void {
        initWhatsAppLinks();
        initAos();
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initPageScripts);
      } else {
        initPageScripts();
      }
    </script>
  </body>
</html>
