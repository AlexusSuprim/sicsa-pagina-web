---
import BaseLayout from '@layouts/BaseLayout.astro';
import Button from '@components/ui/Button.astro';
---

<BaseLayout
  title="Página no encontrada"
  description="La página que busca no existe en SICSA GROUP."
>
  <section class="flex min-h-[60vh] items-center py-24">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <p class="text-sm font-semibold uppercase tracking-widest text-brand-red">Error 404</p>
      <h1 class="mt-4 text-4xl font-bold text-brand-navy sm:text-5xl">Página no encontrada</h1>
      <p class="mx-auto mt-4 max-w-md text-gray-600">
        La página que busca no existe o fue movida. Regrese al inicio para continuar navegando.
      </p>
      <div class="mt-8">
        <Button href="/" variant="primary" size="lg">
          Volver al inicio
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
